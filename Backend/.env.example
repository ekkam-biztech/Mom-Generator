# Copy this file to .env and fill in your real values. Never commit the real .env file!

# AWS region where your DynamoDB table and S3 bucket live
AWS_REGION=ap-south-1

# AWS credentials (only needed if NOT running on an EC2 instance with an IAM Role attached)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB table name that stores the MoM history
DYNAMODB_TABLE=MoMHistory

# S3 bucket name that stores the raw meeting transcripts
S3_BUCKET=mom-generator-transcripts

# Google Gemini API key (get one free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Port the backend server runs on
PORT=4000
